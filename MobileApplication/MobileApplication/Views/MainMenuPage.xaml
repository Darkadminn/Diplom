<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApplication.MainMenuPage">
    <ScrollView>
        <StackLayout Background="White" Margin="10">

            <Label Text="Главное меню" HorizontalTextAlignment="Center" TextColor="Black" FontSize="36" Margin="0,20,0,0"/>


            <Button Text="Запись на прием" Margin="0,50,0,0" WidthRequest="300" BackgroundColor="Red" Clicked="ButtonClickedRecord"/>
            <Button Text="Мои посещения" Margin="0,50,0,0" WidthRequest="300" BackgroundColor="Red" Clicked="ButtonClickedVisits"/>

        </StackLayout>
    </ScrollView>
</ContentPage>