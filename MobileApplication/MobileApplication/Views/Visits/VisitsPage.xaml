<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApplication.VisitsPage">
    <ScrollView>
        <StackLayout Background="#f0f0f0">

            <Label Text="Мои посещения" HorizontalTextAlignment="Center" TextColor="Black" FontSize="36" Margin="0,20,0,0"/>


            <StackLayout Background="White" Margin="10,20,10,0">
                <Label Text="Текущие приемы" HorizontalTextAlignment="Center" TextColor="Black" FontSize="20" Margin="0,20,0,20"/>
                <ScrollView HeightRequest="240" Orientation="Horizontal">
                    <StackLayout x:Name="CurrentVisits" Margin="10,0,10,0" Orientation="Horizontal" WidthRequest="300">

                    </StackLayout>
                </ScrollView>
            </StackLayout>

            <StackLayout Background="White" Margin="10,30,10,0">
                <Label Text="Прошедшие приемы" HorizontalTextAlignment="Center" TextColor="Black" FontSize="20" Margin="0,20,0,20"/>
                <ScrollView HeightRequest="240" Orientation="Horizontal">
                    <StackLayout x:Name="OldVisits" Margin="10,0,10,0" Orientation="Horizontal">

                    </StackLayout>
                </ScrollView>
            </StackLayout>

        </StackLayout>
    </ScrollView>
</ContentPage>