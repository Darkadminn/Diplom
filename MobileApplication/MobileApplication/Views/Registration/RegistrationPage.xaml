<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApplication.Views.RegistrationPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             >

    <ScrollView>
        <StackLayout Background="White" HorizontalOptions="Fill" VerticalOptions="Fill">

            <Label Text="Регистрация" HorizontalTextAlignment="Center" TextColor="Black" FontSize="36" Margin="0,10,0,20"/>


            <Label Text="Номер телефона" TextColor="Black" WidthRequest="300"/>
            <Border BackgroundColor="#bef574" Stroke="Black" StrokeThickness="1" StrokeShape="RoundRectangle 5" WidthRequest="300" HeightRequest="40" Margin="0,0,0,10">
                <Entry x:Name="Phone" Placeholder="+7(000)000-00-00" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <toolkit:MaskedBehavior Mask="+7(000)000-00-00" UnmaskedCharacter="0"/>
                    </Entry.Behaviors>
                </Entry>
            </Border>



            <Label Text="Логин" TextColor="Black" WidthRequest="300"/>
            <Border BackgroundColor="#bef574" Stroke="Black" StrokeThickness="1" StrokeShape="RoundRectangle 5" WidthRequest="300" HeightRequest="40" Margin="0,0,0,10">
                <Entry x:Name="Login"/>
            </Border>
            <Label Text="Пароль" TextColor="Black" WidthRequest="300"/>
            <Border BackgroundColor="#bef574" Stroke="Black" StrokeThickness="1" StrokeShape="RoundRectangle 5" WidthRequest="300" HeightRequest="40" Margin="0,0,0,10">
                <Entry x:Name="Password" IsPassword="True" TextChanged="OnPasswordTextChanged"/>
            </Border>
            <Label Text="Повторите пароль" TextColor="Black" WidthRequest="300"/>
            <Border BackgroundColor="#bef574" Stroke="Red" x:Name="BorderRepeatPassword" StrokeShape="RoundRectangle 5" Margin="0,0,0,10" WidthRequest="300">
                <Entry x:Name="RepeatPassword" IsPassword="True" TextChanged="OnRepeatPasswordTextChanged"/>
            </Border>
       
            
            
            <Button Text="Далее" Margin="0,20,0,0" WidthRequest="300" HorizontalOptions="Center"
                BackgroundColor="Red" Clicked="ButtonClickedAddUser"/>



        </StackLayout>
    </ScrollView>
</ContentPage>