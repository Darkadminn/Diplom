<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApplication.RecoveryPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">
    <ScrollView>
        <StackLayout Background="White" HorizontalOptions="Center">

            <Label Text="Введите номер телефона" HorizontalTextAlignment="Center" TextColor="Black" FontSize="36" Margin="0,10,0,20"/>

            <StackLayout VerticalOptions="Center" WidthRequest="300">
                <Label Text="Номер телефона" TextColor="Black"/>
                <Border BackgroundColor="#bef574" Stroke="Black" StrokeThickness="1" StrokeShape="RoundRectangle 5" WidthRequest="300" HeightRequest="40" Margin="0,0,0,10">
                    <Entry x:Name="Phone" Placeholder="+7(XXX)XXX-XX-XX" Keyboard="Numeric">
                        <Entry.Behaviors>
                            <toolkit:MaskedBehavior Mask="+7(000)000-00-00" UnmaskedCharacter="0"/>
                        </Entry.Behaviors>
                    </Entry>
                </Border>
                

                <Button Text="Далее" Margin="0,20,0,0" WidthRequest="300" HorizontalOptions="Center"
                    BackgroundColor="Red" Clicked="ButtonClickedNext"/>
            </StackLayout>
            
        </StackLayout>
    </ScrollView>
</ContentPage>