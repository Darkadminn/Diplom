<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApplication.PhoneConfirmationPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">
    
    <ScrollView>
        <StackLayout Background="White" HorizontalOptions="Center">

            <Label Text="На ваш номер телефона было отправлено SMS-сообщение с кодом подтверждения" HorizontalTextAlignment="Center" 
                   TextColor="Black" FontSize="26" HorizontalOptions="Center" Margin="0,10,0,20"/>


            <Label Text="Код" TextColor="Black"/>
            <Border BackgroundColor="#bef574" Stroke="Black" StrokeThickness="1" StrokeShape="RoundRectangle 5" WidthRequest="300" HeightRequest="40">
                <Entry x:Name="Code" Placeholder="XXXXXX">
                    <Entry.Behaviors>
                        <toolkit:MaskedBehavior Mask="XXXXXX" UnmaskedCharacter="X"/>
                    </Entry.Behaviors>
                </Entry>
            </Border>
            

            <Button Text="Далее" Margin="0,20,0,0" WidthRequest="300" HorizontalOptions="Center"
            BackgroundColor="Red" Clicked="ButtonClickedNext"/>



        </StackLayout>
    </ScrollView>
</ContentPage>