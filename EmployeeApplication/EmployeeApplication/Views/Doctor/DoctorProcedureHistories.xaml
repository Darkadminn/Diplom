<Window x:Class="EmployeeApplication.DoctorProcedureHistories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmployeeApplication"
        mc:Ignorable="d"
        Icon="/Images/icons.ico"
        Title="ИС «МедСервис» - История прохождения процедуры" Height="430" Width="440">
    <StackPanel Margin="10">

        <TextBlock Text="Прохождение процедуры" FontSize="32" HorizontalAlignment="Center"/>
        <DataGrid Name="DataGridProcedureHistories" Height="260" AutoGenerateColumns="False" Width="400" HorizontalAlignment="Center" Margin="0,30,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Width="200" Binding="{Binding date, StringFormat='dd:MM:yyyy'}"/>
                <DataGridTextColumn Header="Время" Width="200" Binding="{Binding date, StringFormat='HH:mm'}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Width="150" Height="35" Content="Назад" Click="ButtonClickBack" Grid.Column="1" HorizontalAlignment="Right" Margin="0,20,10,0"/>
    </StackPanel>
</Window>
