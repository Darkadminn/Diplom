<Window x:Class="EmployeeApplication.AdminAddUpdatePatient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmployeeApplication"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="AdminAddUpdatePatient" 
        Icon="/Images/icons.ico"
        Height="900" 
        Width="850"
        FontSize="18">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
            
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Name="TextBlockHeader" Text="Редактирование пациента" FontSize="32"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ScrollViewer Margin="25,0,10,0" Height="700">
                <StackPanel>
                    <TextBlock Text="Данные о пациенте:" FontSize="24" Margin="0,10,0,20"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                            <TextBlock Text="Поликлиника*"/>
                            <ComboBox Name="WingPolyclinic" Width="300" Height="30" DisplayMemberPath="name" Margin="0,0,0,10"/>
                            <CheckBox Name="NewIndividualCheckBox" Content="Новое физическое лицо" Width="300" Height="30"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Name="IndividualsHeader" Text="Физическое лицо*" FontSize="18"/>
                            <ComboBox Name="Individuals" Width="300" Height="30" DisplayMemberPath="info" IsTextSearchEnabled="True" IsEditable="True"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Name="IndividualStackPanel" Visibility="Visible">
                        <TextBlock Text="Данные о физическом лице:" FontSize="24" Margin="0,10,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="310"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="400"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                <TextBlock Text="Фамилия*"/>
                                <TextBox Name="LastName" PreviewTextInput="LastName_PreviewTextInput" MaxLength="50" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Имя*"/>
                                <TextBox Name="FirstName" PreviewTextInput="FirstName_PreviewTextInput" MaxLength="50" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Отчество"/>
                                <TextBox Name="MiddleName" PreviewTextInput="MiddleName_PreviewTextInput" MaxLength="50" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Полис ОМС"/>
                                <xctk:MaskedTextBox Name="InsurancePolicy" Mask="0000 0000 0000 0000" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Пол*"/>
                                <ComboBox Name="Gender"  Width="300" Height="30">
                                    <ComboBoxItem Content="Мужской"/>
                                    <ComboBoxItem Content="Женский"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="Дата рождения*"/>
                                <DatePicker Name="Birthday" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Телефон"/>
                                <xctk:MaskedTextBox Name="Phone" Mask="+0(000)000-00-00" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="СНИЛС"/>
                                <xctk:MaskedTextBox Name="Snils" Mask="000-000-000 00" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Страховая компания"/>
                                <TextBox Name="InsuranceCompany" MaxLength="100" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Свидетельство о рождении*"/>
                                <xctk:MaskedTextBox Name="birthCertificate" Mask="00 0000000000" Width="300" Height="30"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Данные паспорта:" FontSize="24" Margin="0,10,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="310"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="400"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                <TextBlock Text="Серия"/>
                                <xctk:MaskedTextBox Name="Series" Mask="0000"  Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Дата выдачи"/>
                                <DatePicker Name="DateIssue"  Width="300" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="Номер"/>
                                <xctk:MaskedTextBox Name="Number" Mask="000000" Width="300" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="Кем выдан"/>
                                <TextBox Name="IssuedBy" Width="300" Height="30"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Дети:" FontSize="24" Margin="0,10,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="310"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="400"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                <TextBlock Text="Ребенок"/>
                                <ComboBox Name="Childrens" Width="300" Height="30" DisplayMemberPath="info" Margin="0,0,0,20" IsTextSearchEnabled="True" IsEditable="True"/>
                                <Button Content="Добавить" Width="300" Height="30" FontSize="16" Click="ButtonClickAddChildren" Margin="0,0,0,10"/>
                                <Button Content="Изменить" Width="300" Height="30" FontSize="16" Click="ButtonClickUpdateChildren"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <DataGrid Name="DataGridChildrens" HorizontalAlignment="Center" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DataGridChildrensSelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ФИО" Width="auto" Binding="{Binding fio}"/>
                                        <DataGridTextColumn Header="Свидетельство о рождении" Width="auto" Binding="{Binding birthCertificate}"/>
                                        <DataGridTextColumn Header="Дата рождения" Width="auto" Binding="{Binding birthday, StringFormat= 'dd:MM:yyyy'}"/>
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="-" FontSize = "16" Width="40" Height="20" Click="ButtonClickDeleteChildren"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <Grid Grid.Row="2" Margin="25,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Name="ButtonOperation" Width="200" Height="30" FontSize="16" Grid.Column="0" HorizontalAlignment="Left"/>
            <Button Content="Назад" Width="200" Height="30" FontSize="16" Click="ButtonClickBack" Grid.Column="1" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>

</Window>
