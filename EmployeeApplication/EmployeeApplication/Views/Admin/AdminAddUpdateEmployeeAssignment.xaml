<Window x:Class="EmployeeApplication.AdminAddUpdateEmployeeAssignment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmployeeApplication"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="AdminAddUpdateEmployeeAssignment" 
        Height="800" 
        Width="900"
        Icon="/Images/icons.ico"
        FontSize="18">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Name="TextBlockHeader" Text="Редактирование назначения" FontSize="32"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ScrollViewer Margin="25,0,10,0" Height="600">
                <StackPanel>
                    <TextBlock Text="Данные о назначении:" FontSize="24" Margin="0,10,0,20"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                            <TextBlock Text="Сотрудник*"/>
                            <ComboBox Name="Employees" Width="300" Height="30" Margin="0,0,0,10" DisplayMemberPath="info"/>
                            <TextBlock Text="Дата начала*"/>
                            <DatePicker Name="DateFrom" Width="300" Height="30" Margin="0,0,0,10"/>
                            <TextBlock Text="Корпус*"/>
                            <ComboBox Name="Wings"  Width="300" Height="30" Margin="0,0,0,10" SelectionChanged="Wings_SelectionChanged" DisplayMemberPath="name"/>
                            <TextBlock Text="Кабинет*"/>
                            <ComboBox Name="Cabinets"  Width="300" Height="30" Margin="0,0,0,10" DisplayMemberPath="name"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="Тип*"/>
                            <ComboBox Name="Types"  Width="300" Height="30" Margin="0,0,0,10">
                                <ComboBoxItem Content="Основное"/>
                                <ComboBoxItem Content="Совмещение"/>
                            </ComboBox>
                            <TextBlock Text="Дата окончания*"/>
                            <DatePicker Name="DateTo" Width="300" Height="30" Margin="0,0,0,10"/>
                            <TextBlock Text="Отделение*"/>
                            <ComboBox Name="Departments"  Width="300" Height="30" Margin="0,0,0,10" SelectionChanged="Departments_SelectionChanged" DisplayMemberPath="name"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Расписание:" FontSize="24" Margin="0,10,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="490"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                            <TextBlock Text="Время начала смены" FontSize="18"/>
                            <xctk:MaskedTextBox Name="TimeStart" Mask="00:00" Width="300" Height="30" Margin="0,0,0,10"/>
                            <TextBlock Text="Время окончания смены" FontSize="18"/>
                            <xctk:MaskedTextBox Name="TimeEnd" Mask="00:00" Width="300" Height="30" Margin="0,0,0,10"/>
                            <TextBlock Text="Дни недели"/>
                            <ListBox Name="WeekDays" SelectionMode="Multiple" Width="300" Height="130" Margin="0,0,0,10">
                                <ListBoxItem Content="Понедельник"/>
                                <ListBoxItem Content="Вторник"/>
                                <ListBoxItem Content="Среда"/>
                                <ListBoxItem Content="Четверг"/>
                                <ListBoxItem Content="Пятница"/>
                                <ListBoxItem Content="Суббота"/>
                                <ListBoxItem Content="Воскресение"/>
                            </ListBox>
                            <Button Content="Добавить" Width="300" Height="30" FontSize="16" Click="ButtonClickAddWorkSchedule" Margin="0,0,0,10"/>
                            <Button Content="Изменить" Width="300" Height="30" FontSize="16" Click="ButtonClickUpdateWorkSchedule"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <DataGrid Name="DataGridWorkSchedules" HorizontalAlignment="Center" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DataGridWorkSchedules_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Время начала" Width="auto" Binding="{Binding timeStart}"/>
                                    <DataGridTextColumn Header="Время окончания" Width="auto" Binding="{Binding timeEnd}"/>
                                    <DataGridTextColumn Header="Дни недели" Width="150" Binding="{Binding weekDaysString}"/>
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="-" FontSize = "16" Width="40" Height="20" Click="ButtonClickDeleteWorkSchedule"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <Grid Grid.Row="2" Margin="25,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Name="ButtonOperation" Width="200" Height="30" FontSize="16" Grid.Column="0" HorizontalAlignment="Left"/>
            <Button Content="Назад" Width="200" Height="30" FontSize="16" Click="ButtonClickBack" Grid.Column="1" HorizontalAlignment="Right"/>
        </Grid>

    </Grid>
</Window>
