<Window x:Class="EmployeeApplication.NurseProcedureHistories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmployeeApplication"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="ИС «МедСервис» - История прохождения процедуры" Height="420" Width="550">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Прохождение процедуры" FontSize="32"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата"/>
                <DatePicker Name="DateProcedureHistory"/>
                <TextBlock Text="Время" Margin="0,10,0,0"/>
                <xctk:MaskedTextBox Name="TimeProcedureHistory" Mask="00:00"/>
                <Button Height="30" Margin="0,20,0,0" Content="Добавить"/>
                <Button Height="30" Margin="0,10,0,0" Content="Изменить"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <DataGrid Name="DataGridProcedureHistories" Height="230" AutoGenerateColumns="False" Width="350" SelectionChanged="DataGridProcedureHistories_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Width="150" Binding="{Binding date, StringFormat='dd:MM:yyyy'}"/>
                        <DataGridTextColumn Header="Время" Width="150" Binding="{Binding date, StringFormat='HH:mm'}"/>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="-" FontSize = "16" Width="40" Height="20" Click="ButtonClickDelete"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="ButtonOperation" Width="150" Height="35" Content="Сохранить" Grid.Column="0" HorizontalAlignment="Left" Click="ButtonClickSave"/>
            <Button Width="150" Height="35" Content="Назад" Click="ButtonClickBack" Grid.Column="1" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
